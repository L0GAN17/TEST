<div class=3D"columnLayout single" data-layout=3D"single">
<div class=3D"cell normal" data-type=3D"normal">
<div class=3D"innerCell">
<h2 id=3D"UC0203Rozmie=C5=88aniehotovosti-Alternat=C3=ADvnetoky"><span styl=
e=3D"color: rgb(0,0,0);"><span class=3D"inline-comment-marker" data-ref=3D"=
7c4d7548-62cf-4227-b92c-9df77f2d15a6">Alternat=C3=ADvne toky</span></span><=
/h2>
<p><br></p>
<p><strong>A1 =E2=80=93 Zru=C5=A1enie oper=C3=A1cie pred pokra=C4=8Dovan=C3=
=ADm (na mincovke rozmie=C5=88ania)</strong></p>
<ol>
<li><p>Pou=C5=BE=C3=ADvate=C4=BE zvol=C3=AD mo=C5=BEnos=C5=A5 Sp=C3=A4=C5=
=A5/Zru=C5=A1i=C5=A5</p></li>
<li><p>Syst=C3=A9m zru=C5=A1=C3=AD rozpracovan=C3=BA oper=C3=A1ciu a vr=C3=
=A1ti pou=C5=BE=C3=ADvate=C4=BEa na predch=C3=A1dzaj=C3=BAcu obrazovku</p><=
/li>
<li><p>Koniec UC</p></li>
</ol>
<p><br></p>
<p><strong>A2 =E2=80=93 Zru=C5=A1enie oper=C3=A1cie na poplatkovej mincovke=
</strong><span>&nbsp;</span><em>(plat=C3=AD pre varianty s hotovostn=C3=BDm=
 poplatkom =E2=80=93 kroky 5=E2=80=937)</em></p>
<ol>
<li><p>Pou=C5=BE=C3=ADvate=C4=BE zvol=C3=AD mo=C5=BEnos=C5=A5 Sp=C3=A4=C5=
=A5/Zru=C5=A1i=C5=A5</p></li>
<li><p>Syst=C3=A9m zru=C5=A1=C3=AD rozpracovan=C3=BA oper=C3=A1ciu a vr=C3=
=A1ti pou=C5=BE=C3=ADvate=C4=BEa na formul=C3=A1r rozmie=C5=88ania hotovost=
i (krok 2)</p></li>
<li><p>Pou=C5=BE=C3=ADvate=C4=BE m=C3=B4=C5=BEe upravi=C5=A5 nomin=C3=A1ly =
a pokra=C4=8Dova=C5=A5 pod=C4=BEa hlavn=C3=A9ho toku alebo oper=C3=A1ciu uk=
on=C4=8Di=C5=A5</p></li>
</ol>
<p><strong>A3 =E2=80=93 Povinn=C3=A9 pole Popis nie je vyplnen=C3=A9</stron=
g></p>
<ol>
<li><p>Pou=C5=BE=C3=ADvate=C4=BE nezad=C3=A1 hodnotu do po=C4=BEa Popis a z=
vol=C3=AD Ulo=C5=BEi=C5=A5</p></li>
<li><p>Syst=C3=A9m zobraz=C3=AD valida=C4=8Dn=C3=BA hl=C3=A1=C5=A1ku "Popis=
 je povinn=C3=BD" a neumo=C5=BEn=C3=AD ulo=C5=BEenie</p></li>
<li><p>Pou=C5=BE=C3=ADvate=C4=BE dopln=C3=AD Popis</p></li>
<li><p>N=C3=A1vrat na krok 9 hlavn=C3=A9ho toku</p></li>
</ol>
</div>
</div>
</div>
<div class=3D"columnLayout single" data-layout=3D"single">
<div class=3D"cell normal" data-type=3D"normal">
<div class=3D"innerCell">
